{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PerspectiveLab",
  "version": "1.0.0",
  "identifier": "fi.hamk.perspectivelab",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:8000",
    "beforeDevCommand": "node ../desktop/ensure-backend-dev.mjs",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PerspectiveLab",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:8000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "app", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {},
      "appimage": {}
    }
  }
}
