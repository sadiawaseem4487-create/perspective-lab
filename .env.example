# Application
ENVIRONMENT=production
APP_VERSION=1.0.0
CASE_ID=sao-paulo-dropout
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# --- OpenRouter (recommended) ---
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-key-here
OPENAI_MODEL=openai/gpt-4o-mini

# --- Or use OpenAI directly ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=2

# Security (required in production)
EXPORT_API_KEY=change-this-to-a-long-random-secret
CORS_ORIGINS=https://your-domain.example
ALLOWED_HOSTS=your-domain.example,localhost

# Rate limiting
RATE_LIMIT_ASK=10/minute

# Database (optional — defaults to backend/data/sessions.db)
# DATABASE_PATH=/app/backend/data/sessions.db
